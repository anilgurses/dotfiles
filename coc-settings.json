{
    "languageserver": {
    "ccls": {
      "command": "ccls",
      "filetypes": ["c", "cc", "cpp", "cuda", "objc", "objcpp"],
      "rootPatterns": [".ccls",".git/",".ccls-root", "compile_commands.json"],
      "initializationOptions": {
          "index": {
            "onChange": true
          },
          "highlight": {
             "lsRanges": true
          },
          "cache": {
          "directory": "/tmp/ccls"
        },
        "client": {
          "snippetSupport": true
        }
      }
    }
  }
}
